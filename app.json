{
  "expo": {
    "name": "Mobileapplication",
    "slug": "Mobileapplication",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./app/assets/android-icon-foreground.png",
        "backgroundImage": "./app/assets/android-icon-background.png",
        "monochromeImage": "./app/assets/android-icon-monochrome.png"
      },
      "permissions": ["android.permission.RECEIVE_BOOT_COMPLETED", "android.permission.SCHEDULE_EXACT_ALARM"]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./app/assets/icon.png",
          "color": "#6C63FF",
          "sounds": []
        }
      ]
    ],
    "web": {
      "favicon": "./app/assets/favicon.png"
    }
  }
}
